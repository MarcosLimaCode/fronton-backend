{
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src", // <--- ESSENCIAL: Diz que a base é a pasta src
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2020",
    "esModuleInterop": true,
    "ignoreDeprecations": "6.0"
  },
  "include": ["src/**/*"], // <--- Garante que só o que está em src será compilado
  "exclude": ["node_modules", "**/*.test.ts"]
}
